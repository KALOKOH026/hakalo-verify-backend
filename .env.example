# Copy this to .env and fill in values for development/production.
SECRET_KEY=replace-with-a-secret
DEBUG=True
# Comma-separated list, e.g. "localhost,127.0.0.1"
ALLOWED_HOSTS=localhost,127.0.0.1

# Example Postgres DB URL:
# DATABASE_URL=postgres://user:password@localhost:5432/mydb
# If omitted, settings.py will fall back to sqlite:///<BASE_DIR>/db.sqlite3
DATABASE_URL=

# Optional: allow all CORS origins in development (not recommended for production)
CORS_ALLOW_ALL_ORIGINS=True
